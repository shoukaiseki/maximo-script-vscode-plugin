{
  "name": "maximo-script-helper",
  "displayName": "Maximo Script Helper",
  "description": "Maximo自动化脚本开发助手，提供智能代码补全、语法提示等功能",
  "version": "1.3.2",
  "publisher": "shoukaiseki",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/shoukaiseki/maximo-script-vscode-plugin.git"
  },
  "bugs": {
    "url": "https://gitee.com/shoukaiseki/maximo-script-vscode-plugin/issues"
  },
  "scripts": {
    "install": "npm install&&cd webview-ui && npm install",
    "vscode:prepublish": "npm run compile",
    "compile-java": "compile-java.bat",
    "compile-webview": "cd webview-ui && npm run build",
    "compile": "npm run compile-webview && webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onCommand:maximoScript.showConfig",
    "onCommand:maximoScript.pushToMaximo",
    "onCommand:extension.triggerComplete"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maximoScript.showConfig",
        "title": "Maximo Script: 打开配置"
      },
      {
        "command": "maximoScript.showLogs",
        "title": "Maximo Script: 查看日志"
      },
      {
        "command": "maximoScript.setLogLevel",
        "title": "Maximo Script: 设置日志级别"
      },
      {
        "command": "maximoScript.pushToMaximo",
        "title": "Maximo Script: 推送到 Maximo"
      },
      {
        "command": "maximoScript.pushXmlToMaximo",
        "title": "Maximo Script: 推送 XML 到 Maximo"
      },
      {
        "command": "maximoScript.fetchReflection",
        "title": "Maximo Script: 通过maximo接口获取类反射信息"
      },
      {
        "command": "maximoScript.fetchReflectionLocal",
        "title": "Maximo Script: 通过本地反射获取类反射信息"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "maximoScript.pushToMaximo",
          "when": "editorLangId == javascript",
          "group": "navigation@1"
        },
        {
          "command": "maximoScript.pushXmlToMaximo",
          "when": "editorLangId == xml",
          "group": "navigation@1"
        },
        {
          "command": "maximoScript.fetchReflection",
          "when": "editorLangId == javascript && editorHasSelection",
          "group": "navigation@2"
        },
        {
          "command": "maximoScript.fetchReflectionLocal",
          "when": "editorLangId == javascript && editorHasSelection",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Maximo Script Helper",
      "properties": {
        "maximoScript.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Maximo服务器地址"
        },
        "maximoScript.authType": {
          "type": "string",
          "enum": [
            "maxauth",
            "apikey"
          ],
          "default": "maxauth",
          "description": "认证方式：MAXAUTH 或 API Key"
        },
        "maximoScript.maxauth": {
          "type": "string",
          "default": "",
          "description": "Maximo认证信息（Base64编码的用户名:密码）"
        },
        "maximoScript.apiKey": {
          "type": "string",
          "default": "",
          "description": "Maximo REST API 的 API Key"
        },
        "maximoScript.version": {
          "type": "string",
          "enum": [
            "9.1"
          ],
          "default": "9.1",
          "description": "Maximo版本"
        },
        "maximoScript.apiType": {
          "type": "string",
          "enum": [
            "oslc",
            "rest"
          ],
          "default": "oslc",
          "description": "接口类型：OSLC API 或 REST API"
        },
        "maximoScript.completionMode": {
          "type": "string",
          "enum": [
            "vscode",
            "default",
            "reflection"
          ],
          "default": "vscode",
          "description": "补全模式：VSCode模式（使用VSCode内置补全）、默认模式（插件补全）、反射模式（Java反射补全）"
        },
        "maximoScript.localApiPath": {
          "type": "string",
          "default": "~/.sks/maximo-script-helper/reflection-data",
          "description": "本地API反射数据目录路径（JSON文件所在目录）"
        },
        "maximoScript.scriptStoragePath": {
          "type": "string",
          "default": "masscript",
          "description": "脚本存放目录（用于存储从 Maximo 导出的脚本文件，默认为项目根目录下的 masscript 文件夹）"
        },
        "maximoScript.aliasName": {
          "type": "string",
          "default": "",
          "description": "别名（用于推送脚本时保存历史记录）"
        },
        "maximoScript.exportDirectory": {
          "type": "string",
          "default": "",
          "description": "导出脚本目录（用于存储导出的 Maximo 脚本，持久化保存）"
        },
        "maximoScript.envnum": {
          "type": "string",
          "default": "default",
          "description": "当前环境名称（用于切换不同的 Maximo 服务器配置）"
        },
        "maximoScript.langcode": {
          "type": "string",
          "default": "en",
          "description": "Maximo 界面语言代码（如：EN-English, ZH-简体中文, JA-日本語等）"
        },
        "maximoScript.enableJSDocParsing": {
          "type": "boolean",
          "default": true,
          "description": "启用 JSDoc 类型注释解析"
        },
        "maximoScript.enableTypeInference": {
          "type": "boolean",
          "default": true,
          "description": "启用返回值类型推断（支持链式调用）"
        },
        "maximoScript.autoGenerateReflectionApi": {
          "type": "boolean",
          "default": false,
          "description": "自动生成反射API（需要Maximo接口支持，开启后会自动调用 SKS_REFLECT_HELPER 接口获取类信息并生成本地类型定义文件）"
        },
        "maximoScript.autoGenerateReflectionApiLocal": {
          "type": "boolean",
          "default": false,
          "description": "自动通过本地jar生成反射API（当Maximo接口失败时作为降级方案，使用本地JAR包反射获取类信息）"
        },
        "maximoScript.jarDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Maximo JAR 文件目录列表（用于实时反射获取 API 数据）"
        },
        "maximoScript.additionalJars": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "额外的 JAR 文件完整路径列表"
        },
        "maximoScript.jdkPath": {
          "type": "string",
          "default": "",
          "description": "JDK 安装路径（用于调用 Java 反射 API，例如：C:/Program Files/Java/jdk-11）"
        },
        "maximoScript.enableHttpLog": {
          "type": "boolean",
          "default": false,
          "description": "启用 HTTP 请求日志保存（生成 IntelliJ IDEA HTTP Client 格式的 .http 文件）"
        }
      }
    },
    "snippets": [
      {
        "language": "javascript",
        "path": "./snippets/maximo-js.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.19.0",
    "copy-webpack-plugin": "^14.0.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
}
