<?xml version="1.0" encoding="UTF-8"?>

<presentation id="IBM_MAXAPPXML_HISTORY" ismobile="false" mboname="IBM_MAXAPPXML_HISTORY" resultstableid="results_showlist" version="6.0.0">
	<page id="mainrec" scroll="false">
		<include controltoclone="pageHeader" id="INCLUDE-pageHeader"/>
		<clientarea id="clientarea">
			<tabgroup id="maintabs" style="form">
				<tab default="true" id="results" label="List" type="list">
					<!-- <buttongroup id="main_toolbar">
						<pushbutton mxevent="reloadcache" id="reloadcache" label="Reload Cache" style="primary"/>
					</buttongroup> -->
					<menubar event="search" id="actiontoolbar1" sourcemethod="getAppSearchOptions"/>
					<table id="results_showlist" inputmode="readonly" label="TABLE TITLE" mboname="IBM_MAXAPPXML_HISTORY" selectmode="multiple"  orderby="IBM_MAXAPPXML_HISTORYID desc" >
						<tablebody displayrowsperpage="20" filterable="true" filterexpanded="true" id="results_showlist_tablebody" >
							<tablecol dataattribute="IBM_MAXAPPXML_HISTORYID" filterable="false" id="results_showlist_column_select" mxevent="toggleselectrow" mxevent_desc="Select Row {0}" sortable="false" type="event"/>
							<tablecol label="ID" dataattribute="IBM_MAXAPPXML_HISTORYID" id="results_showlist_column_link" mxevent="selectrecord" mxevent_desc="Go To %1" type="link" usefieldsizegroup="false"/>
							<tablecol dataattribute="APP" id="results_showlist_column1" mxevent="selectrecord" mxevent_desc="Go To %1" type="link" />
							<tablecol dataattribute="ALIASNAME" id="results_showlist_column2"/>
							<tablecol dataattribute="HOSTNAME" id="results_showlist_column4"/>
							<tablecol dataattribute="LANGCODE" id="results_showlist_column3"/>
							<tablecol dataattribute="CREATEPERSON" id="results_showlist_column5"/>
							<tablecol dataattribute="CREATETIME" id="results_showlist_column6"/>
							<tablecol filterable="false" id="results_bookmark" mxevent="BOOKMARK" mxevent_desc="Add to Bookmarks" mxevent_icon="btn_addtobookmarks.gif" sortable="false" type="event"/>
						</tablebody>
					</table>
				</tab>
				<tab id="main" label="Main" type="insert">
					<section id="maintab_section">
						<sectionrow id="maintab_section_row1">
							<sectioncol id="maintab_section_col1">
								<section id="maintab_section_col1_section">
									<textbox  inputmode="readonly" dataattribute="AUTOSCRIPT" id="maintab_attr_autoscript"/>
									<textbox dataattribute="ALIASNAME" id="maintab_attr_aliasname"/>
									<textbox dataattribute="HOSTNAME" id="maintab_attr_hostname"/>
									<textbox dataattribute="DESCRIPTION" id="maintab_attr_description"/>
								</section>
							</sectioncol>
							<sectioncol id="maintab_section_col2">
								<section id="maintab_section_col2_section">
									<textbox  inputmode="readonly" dataattribute="VERSION" id="maintab_attr_version"/>
									<textbox  dataattribute="CREATEPERSON" id="maintab_attr_createperson" inputmode="readonly"/>
									<textbox  dataattribute="CREATETIME" id="maintab_attr_createtime" inputmode="readonly" lookup="datelookup"/>
								</section>
							</sectioncol>
						</sectionrow>
						<sectionrow id="maintab_section_row2">
						<multilinetextbox inputmode="readonly" dataattribute="SOURCE" id="maintab_attr_source" rows="15" columns="80"/>
						</sectionrow>
						<sectionrow id="GFNuDOt5gHfZNMME">
						<multilinetextbox inputmode="readonly" dataattribute="DESCRIPTION_LONGDESCRIPTION" id="bv7cWnEdeE4WZMNz" rows="15" columns="80"/>
						</sectionrow>
					</section>
				</tab>
			</tabgroup>
		</clientarea>
		<include controltoclone="pageFooter" id="INCLUDE-pageFooter"/>
	</page>

	<dialog beanclass="psdi.webclient.system.beans.QbeBean" id="searchmore" inputmode="query" label="More Search Fields">
		<section id="searchmore_1">
			<textbox dataattribute="IBM_MAXAPPXML_HISTORYID" id="searchmore_attr1"/>
			<textbox dataattribute="DESCRIPTION" id="searchmore_attr2"/>
			<textbox dataattribute="DESCRIPTION_LONGDESCRIPTION" id="searchmore_attr3"/>
			<checkbox dataattribute="HASLD" id="searchmore_attr4"/>
			<textbox dataattribute="SOURCE" id="searchmore_attr5"/>
			<textbox dataattribute="VERSION" id="searchmore_attr6"/>
			<textbox dataattribute="CREATETIME" id="searchmore_attr7" lookup="datelookup"/>
			<textbox dataattribute="CREATEPERSON" id="searchmore_attr8"/>
			<textbox dataattribute="HOSTNAME" id="searchmore_attr9"/>
			<textbox dataattribute="ALIASNAME" id="searchmore_attr10"/>
			<textbox dataattribute="AUTOSCRIPT" id="searchmore_attr11"/>
		</section>
		<buttongroup id="searchmore_buttongroup">
			<pushbutton default="true" id="searchmore_buttongroup_1" label="Find" mxevent="dialogok"/>
			<pushbutton id="qbe_restoreappdefault_button" label="恢复应用程序缺省值" mxevent="qbeclear"/>
			<pushbutton id="qbe_revisebutton" label="修订" menutype="SEARCHMOREREVISE" targetid="searchmore"/>
			<pushbutton id="searchmore_buttongroup_3" label="Cancel" mxevent="qbecancel"/>
		</buttongroup>
	</dialog>

	<dialog beanclass="psdi.webclient.system.beans.ViewBookmarksBean" id="searchbook" label="我的书签" mboname="IBM_MAXAPPXML_HISTORY">
		<table id="bookmarks_table" inputmode="readonly" selectmode="single">
			<tablebody displayrowsperpage="20" filterable="true" id="bookmarks_table_tablebody">
				<tablecol dataattribute="IBM_MAXAPPXML_HISTORYID" id="bookmarks_tablecolumn_1" mxevent="selectrecord" type="link"/>
				<tablecol dataattribute="description" id="bookmarks_tablecolumn_2"/>
				<tablecol filterable="false" id="bookmarks_tablecolumn_3" mxevent="instantdelete" mxevent_desc="Delete" mxevent_icon="btn_delete.gif" sortable="false" type="event"/>
			</tablebody>
		</table>
		<buttongroup id="bookmarks_2">
			<pushbutton default="true" id="bookmarks_2_1" label="确定" mxevent="dialogok"/>
		</buttongroup>
	</dialog>
	<configurationblock id="datastore_configurationblock">
	</configurationblock>
</presentation>
